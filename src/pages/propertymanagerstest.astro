---
import { Image } from 'astro:assets';
import Diff from '../components/Diff.astro';
import Markdown from '../components/Markdown.astro';
import Layout from '../layouts/Layout.astro';

// Use an image from /public (served from the site root):
const corgi = '/in-process1.jpg';

// Images in /public are served from the site root:
const beforeImage = '/before.jpg';
const afterImage = '/after.jpg';

// In local dev, Netlify format auto-detection may not run the same way,
// so force WebP (optional).
const forceWebP = process.env.NODE_ENV === 'development';

const makeNetlifySrcSet = (url: string) =>
  [640, 1280, 2048]
    .map((w) => `/.netlify/images?url=${url}&w=${w}${forceWebP ? '&fm=webp' : ''} ${w}w`)
    .join(', ');

const beforeImageSrcSet = makeNetlifySrcSet(beforeImage);
const afterImageSrcSet = makeNetlifySrcSet(afterImage);

const sizes = '(max-width: 1024px) 100vw, 1024px';

const astroImageSnippet = `
## Optimizing the time between check-out and check-in

Our team gets everything done and works with your property calender to keep all your properties earning.

~~~jsx
---
 // Before...
PROPERTY: 1234 Consitution Drive
task: from 'Hostaway'; touch up paint in all areas
task: from 'Hostaway'; insure all showers and sinks draining correctly
task: from 'Hostaway'; evalaute pool area - report of flaking cement from cleaners
task: from 'Breezeway'; fix supply door as hinges are loose.
task: from 'Breezeway'; fix inoperable RING system
---
 // After ...
<Image src={corgi} alt="Corgi" /* ... additional props */ />
~~~
`;

const originalVsCdnSnippet = `
## Before vs. After: slide to compare

~~~jsx
// <== On the left, BEFORE
<img
task: from 'Hostaway'; touch up paint in all areas
task: from 'Hostaway'; touch up paint in all areas
task: from 'Hostaway'; touch up paint in all areas
task: from 'Hostaway'; touch up paint in all areas
/>

// ==> On the right, AFTER
<img
  task complete: from 'Hostaway'; touch up paint in all areas
  task complete: from 'Hostaway'; touch up paint in all areas
  task complete: from 'Hostaway'; touch up paint in all areas
/>
~~~
`;

const devModeWarning = `
In local development, optimization is performed locally without automatic format
detection, so format is set to WebP.
`;
---

<Layout title="Image CDN">
  <div class="flex flex-col gap-12 sm:gap-16">
    <section>
      <h1>Keeping Your Properties' 5 Stars ranking Is Our Way of Life</h1>
    </section>

    <section>
      <Markdown content={astroImageSnippet} class="mb-8" />
      <figure>
        <Image src={corgi} alt="Corgi" class="border-2 border-white rounded-lg" />
        <figcaption class="mt-2 text-sm italic">
          In Process Photo: Sanding fromm 80 Grit to 280 Grit, Then apply durable clear coat.  </a>
        </figcaption>
      </figure>
    </section>

    <section>
      <Markdown content={originalVsCdnSnippet} class="mb-8" />

      <Diff class="border-2 border-white rounded-lg image-diff aspect-3/2">
        <Fragment slot="item-1">
          <div>
            <div class="relative">
              <span
                class="hidden absolute py-1.5 px-2.5 text-sm rounded-md bg-gray-900/70 top-2.5 left-2.5"
              ></span>

              <!-- BEFORE -->
              <img srcset={beforeImageSrcSet} sizes={sizes} alt="Before" />
            </div>
          </div>
        </Fragment>

        <Fragment slot="item-2">
          <div>
            <div class="relative">
              <span
                class="hidden absolute py-1.5 px-2.5 text-sm rounded-md bg-gray-900/70 top-2.5 right-2.5"
              ></span>

              <!-- AFTER -->
              <img srcset={afterImageSrcSet} sizes={sizes} alt="After" />
            </div>
          </div>
        </Fragment>
      </Diff>

      {forceWebP ? <Markdown content={devModeWarning} class="mt-4" /> : null}
    </section>
  </div>
</Layout>

<script>
  const images = document.querySelectorAll('.image-diff img');

  images.forEach((image) => {
    if (image.complete) showImageSize(image);
    else image.addEventListener('load', () => showImageSize(image));
  });

  function showImageSize(image) {
    const entry = window?.performance?.getEntriesByName(image.currentSrc)?.[0];
    if (entry && entry.encodedBodySize) {
      const overlay = image.previousElementSibling;
      if (overlay) {
        overlay.classList.remove('hidden');
        overlay.textContent = `Size: ${Math.ceil(entry.encodedBodySize / 1024)}KB`;
      }
    }
  }
</script>
